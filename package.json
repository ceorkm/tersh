{
  "name": "tersh",
  "version": "0.0.0",
  "description": "Tersh — AI-agent-first SSH/SFTP client. Drag images onto the terminal, the remote AI agent sees them.",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite --config frontend/vite.config.ts --configLoader runner",
    "build": "tsc -b frontend/tsconfig.json && vite build --config frontend/vite.config.ts --configLoader runner",
    "preview": "vite preview --config frontend/vite.config.ts --configLoader runner",
    "tauri": "tauri --config backend/tauri.conf.json",
    "tauri:dev": "tauri dev --config backend/tauri.conf.json",
    "tauri:build": "tauri build --config backend/tauri.conf.json",
    "type-check": "tsc -p frontend/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.0",
    "@xterm/addon-fit": "0.10.0",
    "@xterm/addon-unicode-graphemes": "0.4.0",
    "@xterm/xterm": "5.5.0",
    "lucide-react": "1.7.0",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.0",
    "@types/node": "22.10.5",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "@vitejs/plugin-react": "5.2.0",
    "typescript": "5.7.2",
    "vite": "6.4.2"
  }
}
